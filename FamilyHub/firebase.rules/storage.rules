rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profilbilder: jeder eingeloggte Nutzer darf lesen, nur Eigentümer schreibt
    match /avatars/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // max 2MB
        && request.resource.contentType.matches('image/.*');
    }

    // Bon-Fotos: nur Familienmitglieder (familyId im Pfad)
    match /receipts/{familyId}/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // max 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // Gesundheits-Exporte (PDF): nur Eigentümer
    match /health-exports/{userId}/{file} {
      allow read, write: if request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024; // max 10MB
    }

    // Alles andere verbieten
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
